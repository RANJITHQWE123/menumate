{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "menumate",
  "main": "worker.js",
  "compatibility_date": "2026-07-15",
  "assets": {
    "directory": "./static",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    { "binding": "DB" }
  ],
  "vars": {
    "LLM_BASE_URL": "https://api.openai.com/v1",
    "LLM_MODEL": "gpt-4o-mini"
  }
}
