{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "menumate",
  "main": "worker.js",
  "compatibility_date": "2026-07-15",
  "assets": {
    "directory": "./static",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    { "binding": "DB" }
  ],
  "ai": {
    "binding": "AI"
  }
}
